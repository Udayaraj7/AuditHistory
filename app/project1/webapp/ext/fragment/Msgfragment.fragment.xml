
<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns="sap.m">
    <MultiInput
        id="msgValueInput"
        core:require="{ handler: 'project1/ext/fragment/Msgfragment'}"
        editable="{= !${IsActiveEntity} }"
        showValueHelp="true"
        valueHelpRequest="handler.onValueHelpRequest"
        tokenUpdate="handler.onTokenUpdate"
        >
 
        <dependents>
            <SelectDialog
                title="Select Issue Types"
                multiSelect="true"
                rememberSelections="true"
                growing="true"
                growingThreshold="150"
                contentWidth="50%"
                items="{/msgValueHelp}"
                search="handler.onValueHelpSearch"
                confirm="handler.handleValueHelpClose"
		        cancel="handler.handleValueHelpClose">
 
                <StandardListItem
                    title="{value}" />   
            </SelectDialog>
        </dependents>
    </MultiInput>
</core:FragmentDefinition>


